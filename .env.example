# --- GlobalMeet ---
# Option A: REST API
GLOBALMEET_API_URL=https://api.globalmeet.com
GLOBALMEET_API_KEY=your_api_key
GLOBALMEET_API_SECRET=your_api_secret
# Option B: SFTP file drops
GLOBALMEET_SFTP_HOST=
GLOBALMEET_SFTP_USER=
GLOBALMEET_SFTP_PASSWORD=
GLOBALMEET_SFTP_PATH=/reports/

# --- Array ---
ARRAY_API_URL=https://api.arrayeducation.com
ARRAY_API_KEY=your_api_key
ARRAY_API_SECRET=your_api_secret

# --- Pigeonhole ---
PIGEONHOLE_API_URL=https://api.pigeonholelive.com
PIGEONHOLE_API_TOKEN=your_api_token
PIGEONHOLE_WORKSPACE_ID=your_workspace_id
